# syntax=docker/dockerfile:1.6

# Dedicated image for the `generate-c-bindings` job only.
#
# It carries just what's needed to *generate* the C bindings:
#   * the Emscripten SDK (base image) -- so the bindings are produced the normal
#     way, with EM_USE_HOST_HEADERS=0, against the Emscripten sysroot;
#   * the MRBind / Clang toolchain (install_deps_ubuntu.sh) -- to build MRBind
#     and parse the C++ headers.
#
# Deliberately NOT derived from the full meshlib-emscripten image: generating the
# bindings only *parses* headers (the thirdparty headers come from the submodule
# checkout), it never compiles MeshLib -- so this image needs neither the prebuilt
# Emscripten thirdparty libraries nor CUDA. Keeping it separate also stops the
# wasm build/test jobs from paying for the Clang toolchain in their image pull.

FROM emscripten/emsdk:4.0.10-arm64

COPY scripts/mrbind/install_deps_ubuntu.sh scripts/mrbind/install_deps_ubuntu.sh
COPY scripts/mrbind/clang_version.txt scripts/mrbind/clang_version.txt

RUN <<EOF
    set -e
    # configure timezone
    export DEBIAN_FRONTEND=noninteractive
    export DEBCONF_NONINTERACTIVE_SEEN=true
    echo 'tzdata tzdata/Areas select Etc' | debconf-set-selections
    echo 'tzdata tzdata/Zones/Etc select UTC' | debconf-set-selections
    # use more reliable mirror
    sed -i 's http://ports.ubuntu.com/ubuntu-ports/ http://mirror.eu.ossplanet.net/ubuntu-ports/ ' /etc/apt/sources.list
    # install packages
    apt-get update -qqy
    apt-get install -qqy --no-install-recommends \
        tzdata git pkg-config ninja-build gettext
    # Clang and the rest of the MRBind build/parse dependencies (no CUDA -- see above)
    ./scripts/mrbind/install_deps_ubuntu.sh
    # clean downloaded files
    apt-get clean
    rm -rf /var/lib/apt/lists/*
EOF
