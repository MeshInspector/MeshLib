# syntax=docker/dockerfile:1.6

# This image is used to generate C bindings (once, they are then sent to all other platforms).
# Generating C bindings requires Emscripten SDK on most platforms, see `thirdparty/mrbind/docs/generating_c.md#option-a`.
# We could choose a platform here that doesn't need EMSDK, but it's desirable to use EMSDK to check that the process actually works,
#   since this can be used on all OSes, while the EMSDK-less process only works on a few of them.

FROM emscripten/emsdk:4.0.10-arm64

COPY scripts/mrbind/install_deps_ubuntu.sh scripts/mrbind/install_deps_ubuntu.sh
COPY scripts/mrbind/clang_version.txt scripts/mrbind/clang_version.txt

# URL and metadata are TAB-separated (required by apt's mirror method)
COPY <<EOF /etc/apt/mirrors.list
http://archive.ubuntu.com/ubuntu/	priority:1 arch:amd64
http://mirror.eu.ossplanet.net/ubuntu/	priority:2 arch:amd64
http://ports.ubuntu.com/ubuntu-ports/	priority:1 arch:arm64
http://mirror.eu.ossplanet.net/ubuntu-ports/	priority:2 arch:arm64
EOF

COPY <<EOF /etc/apt/sources.list.d/ubuntu.sources
Types: deb
URIs: mirror+file:/etc/apt/mirrors.list
Suites: jammy jammy-updates jammy-security jammy-backports
Components: main restricted universe multiverse
Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg
EOF

COPY <<EOF /etc/apt/sources.list
EOF

RUN <<EOF
    set -e
    export DEBIAN_FRONTEND=noninteractive
    # MRBind dependencies
    ./scripts/mrbind/install_deps_ubuntu.sh
    # clean downloaded files
    apt-get clean
    rm -rf /var/lib/apt/lists/*
EOF

RUN useradd -u 8877 -m aws-user
RUN useradd -u 1001 -m github-user
USER github-user
