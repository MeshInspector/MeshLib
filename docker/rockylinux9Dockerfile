FROM rockylinux:9 AS build

RUN echo "install_weak_deps=false" >> /etc/dnf/dnf.conf && \
    dnf -y install --enablerepo crb \
        git cmake ninja-build clang-devel \
        $(: vcpkg requirements ) \
        curl-minimal zip unzip tar \
        $(: vcpkg package requirements ) \
        autoconf-archive libtool libudev-devel libXcursor-devel libXi-devel libXinerama-devel libXrandr-devel mesa-libGL-devel perl-core \
        && \
    dnf clean all

WORKDIR /opt

ENV VCPKG_VERSION=2024.10.21
RUN git clone https://github.com/microsoft/vcpkg.git --branch $VCPKG_VERSION --single-branch && \
    cd vcpkg && \
    ./bootstrap-vcpkg.sh -disableMetrics

WORKDIR /opt/vcpkg

ENV VCPKG_TRIPLET=x64-linux-dynamic

# build vcpkg packages
COPY requirements/vcpkg-linux.txt requirements.txt
RUN echo "set(VCPKG_BUILD_TYPE release)" >> triplets/community/${VCPKG_TRIPLET}.cmake && \
    ./vcpkg install --host-triplet=${VCPKG_TRIPLET} $(cat requirements.txt | tr '\n' ' ') && \
    rm -rf buildtrees downloads 

RUN mkdir /home/MeshLib
WORKDIR /home/MeshLib

# copy files
COPY .git .git
COPY cmake cmake
COPY scripts scripts
COPY source source
COPY thirdparty thirdparty

ENV MR_STATE=DOCKER_BUILD
ENV MESHLIB_USE_VCPKG=ON
ENV VCPKG_ROOT=/opt/vcpkg

# build and install thirdparty
RUN ./scripts/build_thirdparty.sh


FROM nvidia/cuda:12.6.0-devel-rockylinux9 AS production

RUN mkdir /usr/local/lib/meshlib-thirdparty-lib
WORKDIR /usr/local/lib/meshlib-thirdparty-lib

COPY scripts/install_thirdparty.sh scripts/install_thirdparty.sh

COPY --from=build /opt/vcpkg /opt/vcpkg
COPY --from=build /home/MeshLib/include /usr/local/lib/meshlib-thirdparty-lib/include
COPY --from=build /home/MeshLib/lib /usr/local/lib/meshlib-thirdparty-lib/lib

ENV MR_STATE=DOCKER_BUILD
ENV MESHLIB_USE_VCPKG=ON
ENV VCPKG_ROOT=/opt/vcpkg
ENV VCPKG_TRIPLET=x64-linux-dynamic

RUN echo "install_weak_deps=false" >> /etc/dnf/dnf.conf && \
    dnf -y install --enablerepo crb \
        git cmake ninja-build clang-devel \
        $(: vcpkg requirements ) \
        curl-minimal zip unzip tar \
        $(: vcpkg package requirements ) \
        autoconf-archive libtool libudev-devel libXcursor-devel libXi-devel libXinerama-devel libXrandr-devel mesa-libGL-devel perl-core \
        $(: CI environment ) \
        time python3-pip rpm-build xorg-x11-server-Xvfb mesa-dri-drivers \
        && \
    dnf clean all

RUN dnf -y install 'dnf-command(config-manager)' && \
    dnf config-manager --add-repo https://cli.github.com/packages/rpm/gh-cli.repo && \
    dnf -y install gh && \
    dnf clean all

RUN ./scripts/install_thirdparty.sh && \
    echo '/usr/local/lib' | tee -a /etc/ld.so.conf && \
    ldconfig

# install aws cli
RUN curl "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o "awscliv2.zip" && \
    unzip awscliv2.zip && \
    ./aws/install --bin-dir /usr/local/bin --install-dir /usr/local/aws-cli --update
