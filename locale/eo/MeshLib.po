#: source/MRViewer/MRViewerSettingsPlugin.cpp:723
#: source/MRViewer/MRViewerSettingsPlugin.cpp:741
msgid "Precision"
msgstr "Precizo"

#: source/MRViewer/MRViewerSettingsPlugin.cpp:688
msgid ""
"The number of digits to be shown after decimal point for length measurements."
msgstr "La nombro de ciferoj por montri post la dekuma punkto por longaj mezuradoj."

#: source/MRViewer/MRViewerSettingsPlugin.cpp:696
msgid "Angular"
msgstr "Angela"

#: source/MRViewer/MRViewerSettingsPlugin.cpp:714
msgid "It selects angular units to be show in the user interface."
